{
	"name": "ohttp-ts",
	"version": "0.2.4",
	"description": "Oblivious HTTP (RFC 9458) implementation with chunked extension support",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"examples": "tsx examples/index.ts",
		"test": "vitest run",
		"test:browser": "vitest run --config vitest.browser.config.ts",
		"test:watch": "vitest",
		"bench": "vitest bench",
		"lint": "biome check src test",
		"format": "biome format --write src test",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"ohttp",
		"oblivious-http",
		"hpke",
		"privacy",
		"encryption",
		"rfc9458",
		"cloudflare-workers"
	],
	"author": "Thibault Meunier",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/thibmeu/ohttp-ts.git"
	},
	"bugs": {
		"url": "https://github.com/thibmeu/ohttp-ts/issues"
	},
	"homepage": "https://github.com/thibmeu/ohttp-ts#readme",
	"dependencies": {
		"hpke": "1.0.6",
		"quicvarint": "0.1.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@hpke/chacha20poly1305": "1.8.0",
		"@panva/hpke-noble": "1.0.6",
		"@playwright/test": "1.58.2",
		"@vitest/browser": "4.1.0",
		"@vitest/browser-playwright": "4.1.0",
		"bhttp-js": "file:vendor/bhttp-js-0.4.0.tgz",
		"esbuild": "0.27.4",
		"esbuild-visualizer": "0.7.0",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "5.9.3",
		"vite": "8.0.0",
		"vitest": "4.1.0"
	},
	"engines": {
		"node": ">=24"
	}
}
